  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.7.5",
    "axios-cookiejar-support": "^5.0.2",
    "iconv-lite": "^0.6.3",
    "image-size": "^1.0.2",
    "node-html-parser": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.11.0",
    "prompts": "^2.4.0",
    "querystring": "^0.2.0",
    "tough-cookie": "^4.1.4",
    "transformation-matrix": "^2.13.0",
    "xml2js": "^0.6.2"
  }
}
